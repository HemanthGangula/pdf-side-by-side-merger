# Application Configuration
# Copy this file to .env.local and update with your values

# Site URL (used for metadata and SEO)
# Default: http://localhost:3000 in development
NEXT_PUBLIC_SITE_URL=htttp://localhost:3000

# Optional: Analytics IDs (uncomment if needed)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Optional: Feature Flags (uncomment if needed)
# NEXT_PUBLIC_ENABLE_ANALYTICS=false
