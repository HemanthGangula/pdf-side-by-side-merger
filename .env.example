# Application Configuration
# Copy this file to .env.local and update with your values

# Site URL (used for metadata, SEO, and sitemap generation)
# For production: https://pdf-side-by-side-merger.vercel.app
# For development: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Search Console Verification
# Get this from Google Search Console -> Settings -> Ownership verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code-here

# Optional: Analytics IDs (uncomment if needed)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Optional: Feature Flags (uncomment if needed)
# NEXT_PUBLIC_ENABLE_ANALYTICS=false
